#include<stdio.h>
int main(){
    float a,b;
    char oper;
    printf("enter 2 numbers for performing desired operation :  ");
    scanf("%f %f",&a,&b);
    printf("enter the operation to perform (+,-,*,/) :  ");
    scanf(" %c",&oper);
    switch(oper){
        case '+':
        printf("addition of given 2 numbers is %.2f\n",a+b);
        break;
        case '-':
        printf("subtraction of given 2 numbers is %.2f\n",a-b);
        break;
        case '*':
        printf("multiplication of given 2 numbers is %.2f\n",a*b);
        break;
        case '/':
        if(b==0){
            printf("division with zero ! Error!\n");
            break;
        }
        else{
        printf("division  of given 2 numbers is %.2f\n",a/b);
        break;
        }
        default:
        printf("invalid operation !\n");
    }
  return 0;  
}