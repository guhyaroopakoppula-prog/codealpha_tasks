#include <stdio.h>

void addMatrix(int r, int c, int A[r][c], int B[r][c]) {
    int sum[r][c];

    printf("\nMatrix Addition:\n");
    for(int i = 0; i < r; i++) {
        for(int j = 0; j < c; j++) {
            sum[i][j] = A[i][j] + B[i][j];
            printf("%d ", sum[i][j]);
        }
        printf("\n");
    }
}

void multiplyMatrix(int r1, int c1, int A[r1][c1],
                    int r2, int c2, int B[r2][c2]) {
    if(c1 != r2) {
        printf("\nMatrix multiplication not possible!\n");
        return;
    }

    int product[r1][c2];

    for(int i = 0; i < r1; i++) {
        for(int j = 0; j < c2; j++) {
            product[i][j] = 0;
            for(int k = 0; k < c1; k++) {
                product[i][j] += A[i][k] * B[k][j];
            }
        }
    }

    printf("\nMatrix Multiplication:\n");
    for(int i = 0; i < r1; i++) {
        for(int j = 0; j < c2; j++) {
            printf("%d ", product[i][j]);
        }
        printf("\n");
    }
}

void transposeMatrix(int r, int c, int A[r][c]) {
    printf("\nTranspose of Matrix:\n");

    for(int j = 0; j < c; j++) {
        for(int i = 0; i < r; i++) {
            printf("%d ", A[i][j]);
        }
        printf("\n");
    }
}

int main() {
    int r, c;

    printf("Enter rows and columns of matrices: ");
    scanf("%d %d", &r, &c);

    int A[r][c], B[r][c];

    printf("Enter elements of Matrix A:\n");
    for(int i = 0; i < r; i++) {
        for(int j = 0; j < c; j++) {
            scanf("%d", &A[i][j]);
        }
    }

    printf("Enter elements of Matrix B:\n");
    for(int i = 0; i < r; i++) {
        for(int j = 0; j < c; j++) {
            scanf("%d", &B[i][j]);
        }
    }

    addMatrix(r, c, A, B);
    multiplyMatrix(r, c, A, r, c, B);
    transposeMatrix(r, c, A);

    return 0;
}